# Neon Postgres (use the pooled connection string)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth.js / NextAuth v5
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Comma-separated emails allowed to sign in (fail-closed if empty)
AUTH_ALLOWLIST=you@example.com

# Optional: public app URL in production
# AUTH_URL=https://your-app.vercel.app

# External services (Tickets 5, 9–10)
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
RESEND_API_KEY=
# From address for digests / approved mail
RESEND_FROM=fs@your-council-domain.org

# Vercel Cron → Authorization: Bearer $CRON_SECRET
CRON_SECRET=generate-a-long-random-string

# Optional: digest recipient (defaults to first AUTH_ALLOWLIST email)
# DIGEST_EMAIL=you@example.com
