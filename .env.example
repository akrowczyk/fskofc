# Neon Postgres (use the pooled connection string)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth.js / NextAuth v5 — simple single-user credentials
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_USER_EMAIL=you@example.com
AUTH_USER_PASSWORD=choose-a-strong-password
# Optional display name on the session
# AUTH_USER_NAME=Financial Secretary

# Optional: public app URL in production
# AUTH_URL=https://your-app.vercel.app

# External services
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
RESEND_API_KEY=
# From address for digests / approved mail
RESEND_FROM=fs@your-council-domain.org

# Vercel Cron → Authorization: Bearer $CRON_SECRET
CRON_SECRET=generate-a-long-random-string

# Optional: digest recipient (defaults to AUTH_USER_EMAIL)
# DIGEST_EMAIL=you@example.com
